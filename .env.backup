# ─────────────────────────────────────────────────────────────
#  SOC Platform  –  Environment Configuration
# ─────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=soc-platform-super-secret-key-change-in-production-2024
FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_URL=sqlite:///soc_platform.db

# Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800

# Threat Intelligence APIs
VIRUSTOTAL_API_KEY=092d6ffe31943cbf0dd759093ab74d4244a9811d3ad6391e37ca97a9a3229c2a
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
OTX_API_KEY=your_otxapi_key_here

# AI
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Email Alerts
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
ALERT_RECIPIENTS=soc@yourcompany.com

# Security
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_HTTPONLY=1
WTF_CSRF_ENABLED=1

# Real-time monitoring
MONITOR_INTERVAL=30
AUTO_REFRESH_INTERVAL=60
